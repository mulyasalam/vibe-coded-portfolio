# --- Required ---
# Postgres connection string. For local dev sign up at neon.tech (free)
# or run Postgres in Docker:
#   docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

ADMIN_PASSWORD=admin
SESSION_SECRET=change-me-to-32+chars-of-randomness

# --- Optional: email forwarding via Resend ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# --- Auto-populated on Vercel when you add a Postgres store ---
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=
# BLOB_READ_WRITE_TOKEN=
